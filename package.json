{
  "name": "henson",
  "version": "0.1.0",
  "description": "A framework for managing AI agents across your projects — shared boards, docs, memory, and companion agent sessions.",
  "type": "module",
  "bin": {
    "henson": "./dist/cli.js"
  },
  "main": "./dist/core/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && cp -r src/server/public dist/server/public",
    "dev": "tsx watch src/cli.ts serve",
    "cli": "tsx src/cli.ts",
    "serve": "tsx src/cli.ts serve",
    "mcp": "tsx src/cli.ts mcp",
    "test": "node --test --import tsx ./test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "chokidar": "^4.0.3",
    "express": "^4.21.2",
    "gray-matter": "^4.0.3",
    "nanoid": "^5.1.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
